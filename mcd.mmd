    USER {
        int user_id PK
        string email UK
        string password_hash
        string first_name
        string last_name
        string phone
        date birth_date
        string profile_picture
        text bio
        boolean is_host
        boolean is_guest
        enum account_status
        timestamp registration_date
        timestamp last_login
        string address_line1
        string address_line2
        string city
        string state
        string postal_code
        string country
        boolean identity_verified
        string government_id
    }
    
    ACCOMMODATION {
        int accommodation_id PK
        string title
        text description
        enum property_type
        enum accommodation_type
        int max_guests
        int bedrooms
        int beds
        int bathrooms
        string address_line1
        string address_line2
        string city
        string state
        string postal_code
        string country
        decimal latitude
        decimal longitude
        boolean has_alarm_system
        enum security_status
        enum validation_status
        text house_rules
        int host_id FK
        timestamp created_at
        timestamp updated_at
    }
    
    AVAILABILITY {
        int availability_id PK
        date start_date
        date end_date
        enum status
        string reason
        int accommodation_id FK
    }
    
    BOOKING {
        int booking_id PK
        date check_in_date
        date check_out_date
        int num_guests
        decimal total_price
        enum booking_status
        timestamp booking_date
        timestamp confirmation_date
        text special_requests
        int guest_id FK
        int accommodation_id FK
        int cancellation_policy_id FK
    }
    
    PRICING {
        int pricing_id PK
        decimal base_nightly_rate
        string currency
        int accommodation_id FK
    }
    
    SEASONAL_RATE {
        int seasonal_rate_id PK
        string name
        date start_date
        date end_date
        decimal rate_multiplier
        decimal fixed_amount
        enum rate_type
        int pricing_id FK
    }
    
    ADDITIONAL_FEE {
        int additional_fee_id PK
        string fee_name
        decimal amount
        enum fee_type
        boolean is_required
        int pricing_id FK
    }
    
    PAYMENT {
        int payment_id PK
        enum payment_type
        decimal amount
        enum payment_status
        string payment_method
        string transaction_id UK
        timestamp payment_date
        timestamp processed_at
        text notes
        int booking_id FK
    }
    
    CANCELLATION_POLICY {
        int policy_id PK
        string policy_name
        text description
        boolean is_default
        int accommodation_id FK
    }
    
    CANCELLATION_RULE {
        int rule_id PK
        int days_before_checkin
        decimal refund_percentage
        decimal penalty_amount
        int policy_id FK
    }
    
    REVIEW {
        int review_id PK
        int cleanliness_rating
        int accuracy_rating
        int communication_rating
        int location_rating
        int checkin_rating
        int value_rating
        decimal overall_rating
        text comment
        timestamp review_date
        int guest_id FK
        int accommodation_id FK
        int booking_id FK
    }
    
    MESSAGE {
        int message_id PK
        text content
        timestamp sent_at
        boolean is_read
        timestamp read_at
        int sender_id FK
        int receiver_id FK
        int booking_id FK
    }
    
    AMENITY {
        int amenity_id PK
        string name UK
        string category
        string icon
    }
    
    ACCOMMODATION_AMENITY {
        int accommodation_id FK
        int amenity_id FK
    }